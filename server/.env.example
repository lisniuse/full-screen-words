PORT=5321
# 必填：至少 16 位的随机字符串，建议 32 位以上。可用 `openssl rand -hex 32` 生成
JWT_SECRET=
JWT_EXPIRES_IN=7d

# SQLite 数据库文件路径（相对 server/ 目录）
DATABASE_PATH=./data.sqlite

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-r1-distill-qwen-32b:free

# 可选代理
HTTP_PROXY=

# 跨域允许的源
CORS_ORIGIN=http://localhost:2022

# 业务时区（打卡日期判定使用），默认 Asia/Shanghai
DEFAULT_TZ=Asia/Shanghai

# 日志级别：trace / debug / info / warn / error / fatal
# 不设时 dev 用 debug、production 用 info
LOG_LEVEL=

# 日志文件目录（生产环境按天滚动写入 app.log）
LOG_DIR=./logs
